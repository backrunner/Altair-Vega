# Browser frontend default rendezvous URL used at build time.
VITE_DEFAULT_RENDEZVOUS_URL=wss://example.invalid/__altair_vega_rendezvous

# Browser same-origin rendezvous path when VITE_DEFAULT_RENDEZVOUS_URL is empty.
VITE_RENDEZVOUS_PATH=__altair_vega_rendezvous

# Native CLI default rendezvous URL used at compile time.
ALTAIR_VEGA_DEFAULT_RENDEZVOUS=wss://example.invalid/__altair_vega_rendezvous

# Disposable launcher default binary URL.
ALTAIR_VEGA_BIN_URL=https://example.invalid/altair-vega-linux-x86_64
